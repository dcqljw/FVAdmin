# ==========================================
# FVAdmin API - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ==========================================

# ---- 基础 ----
PROJECT_NAME=FVAdmin

# ---- MySQL ----
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=fvadmin

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ENABLED=true

# ---- JWT ----
SECRET_KEY=  # 生产环境务必使用强随机字符串
ALGORITHM=HS256

# ---- OSS 对象存储 ----
OSS_URL=
OSS_KEY=
OSS_SECRET=
OSS_BUCKET=

# ---- 日志 ----
LOG_LEVEL=INFO
LOG_FILE_MAX_SIZE=10MB
LOG_FILE_BACKUP_COUNT=5
LOG_TO_CONSOLE=true
LOG_TO_FILE=true
